{
	// Visit https://aka.ms/tsconfig to read more about this file
	// bundling is done by tsup; tsc is only used for typechecking (no emit),
	// so there is no rootDir and scripts/ is typechecked alongside src/
	"include": ["src", "scripts", "vitest.config.mts"],
	"compilerOptions": {
		// File Layout
		"outDir": "./dist",
		"paths": {
			"@config": ["./src/config"],
			"@commands/*": ["./src/commands/*"],
			"@db/*": ["./src/main/db/*"],
			"@main/*": ["./src/main/*"],
			"@routes/*": ["./src/routes/*"]
		},

		// Environment Settings
		// See also https://aka.ms/tsconfig/module
		"module": "nodenext",
		"target": "esnext",
		// "types": [],
		// For nodejs:
		"lib": ["esnext"],
		"types": ["node"],
		// and npm install -D @types/node

		// Other Outputs
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,

		// Stricter Typechecking Options
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,

		// Style Options
		"removeComments": true,
		"resolveJsonModule": true,
		"esModuleInterop": false,
		"forceConsistentCasingInFileNames": true,

		// Recommended Options
		"strict": true,
		"strictNullChecks": true,
		"jsx": "react-jsx",
		"isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": true
	}
}
